# 智慧交通系统 - 数据库配置模板
# 复制此文件为 .env.db，并填入实际的数据库密码

# MySQL 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=intelligent_transportation_system

# 使用说明：
# 1. 复制此文件: cp .env.db.template .env.db
# 2. 编辑 .env.db，将 DB_PASSWORD 修改为你的实际 MySQL 密码
# 3. .env.db 文件不会被上传到 GitHub（已在 .gitignore 中排除）
# 4. 保存后，后端会自动读取配置
